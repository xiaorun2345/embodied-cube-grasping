# Source this file before data recording/training if you want repeatable defaults:
#   set -a; source configs/cube_grasp_smolvla.env; set +a

HF_HOME=${HF_HOME:-$PWD/.cache/huggingface}
HF_LEROBOT_HOME=${HF_LEROBOT_HOME:-$PWD/outputs/lerobot_datasets}
MUJOCO_GL=${MUJOCO_GL:-egl}

DATASET_REPO_ID=${DATASET_REPO_ID:-local/panda_6dof_7ctrl}
DATASET_ROOT=${DATASET_ROOT:-outputs/lerobot_datasets}
OUTPUT_DIR=${OUTPUT_DIR:-outputs/smolvla_panda_6dof_7ctrl}
POLICY_PATH=${POLICY_PATH:-lerobot/smolvla_base}
STEPS=${STEPS:-5000}
BATCH_SIZE=${BATCH_SIZE:-16}
